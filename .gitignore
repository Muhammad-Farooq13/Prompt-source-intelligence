# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Data (large files go in cloud / DVC) ─────────────────────────────────────
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ── Trained models ────────────────────────────────────────────────────────────
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
!models/.gitkeep

# ── Notebooks output ──────────────────────────────────────────────────────────
notebooks/.ipynb_checkpoints/

# ── Reports / figures ────────────────────────────────────────────────────────
reports/figures/*
!reports/figures/.gitkeep

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── HuggingFace cache ─────────────────────────────────────────────────────────
~/.cache/huggingface/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Env files ─────────────────────────────────────────────────────────────────
.env
.env.*

# ── pytest ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── mypy ─────────────────────────────────────────────────────────────────────
.mypy_cache/
